# Per-version doc + indexes are published as GitHub Release assets, not committed.
# Only the latest.* triplet stays in main.
skills/openclaw-docs/versions/openclaw-docs.*.md
!skills/openclaw-docs/versions/openclaw-docs.latest.md

skills/openclaw-docs/versions/openclaw-docs.*.toc.jsonl
!skills/openclaw-docs/versions/openclaw-docs.latest.toc.jsonl

skills/openclaw-docs/versions/openclaw-docs.*.sections.jsonl
!skills/openclaw-docs/versions/openclaw-docs.latest.sections.jsonl

# Local lookup.py cache for fetched non-latest releases
.cache/

# Local refresh log written by the launchd auto-pull job
.refresh.log

# Python bytecode
__pycache__/
*.pyc

# Local dev artifacts
/tmp/
